# Bittensor wallet names
#
# Aliases assigned to the on-disk coldkey / hotkey files, not SS58 addresses.
# Create new ones with:
#   btcli wallet new_coldkey --wallet.name mywallet
#   btcli wallet new_hotkey  --wallet.name mywallet --wallet.hotkey myhotkey
BT_WALLET_COLD=default
BT_WALLET_HOT=default

# Subtensor connection
SUBTENSOR_ENDPOINT="finney"
SUBTENSOR_FALLBACK="wss://lite.sub.latent.to:443"


## MINER ONLY

# HuggingFace personal access token
#   - miners: use "Write" scope to upload model artifacts
#   - everyone else: "Read" scope is fine
# Get one at https://huggingface.co/settings/tokens; starts with `hf_...`.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


## VALIDATOR — TARGON INFERENCE PROVIDER
#
# The scorer service hosts inference per window via Targon. ``TARGON_API_KEY``
# is the only required setting; the rest have working defaults.
TARGON_API_KEY=
TARGON_API_URL=                              # default: https://api.targon.com/tha/v2
TARGON_FIXED_GPU_COUNT=2                     # GPUs per workload
TARGON_ENGINE=sglang                         # sglang | vllm
TARGON_DEFAULT_IMAGE=                        # empty -> per-engine default
TARGON_DATA_VOLUME_MOUNT=/data
TARGON_MAX_MODEL_LEN=65536                   # sglang --context-length
TARGON_MEM_FRACTION=0.8                      # GPU mem reservation
TARGON_SGLANG_CHUNKED_PREFILL_SIZE=4096
TARGON_SGLANG_TOOL_CALL_PARSER=qwen          # set to "none" to disable
TARGON_INITIAL_LOAD_GRACE_SEC=1800           # tolerate 30 min for first-time HF download
TARGON_MODEL_PROBE_TIMEOUT_SEC=5             # /v1/models probe timeout
TARGON_LOAD_POLL_INTERVAL_SEC=15             # interval between /v1/models polls in start()


## VALIDATOR — SCORER service tuning
#
# Block-window cadence; only override if you understand the tradeoff.
# SCORER_TICK_SECONDS=12                      # how often the orchestrator polls
# SCORER_HOTKEY=                              # identity recorded in score_snapshots


## VALIDATOR — VALIDATOR service tuning
#
# WEIGHT_SET_INTERVAL_BLOCKS=180              # weight-emit poll cadence


## ANTI-COPY (CEAC) — R2 buckets + local cache
#
# Cloudflare R2 stores the rollout/score blobs. Without these the
# refresh and worker services cannot read/write the pool. AWS_DEFAULT_REGION
# is required even when only R2 is used (boto3 falls back to it on every
# DynamoDB call too).
# R2_ENDPOINT=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_PRIVATE_BUCKET=affine-anticopy-rollouts
# AWS_DEFAULT_REGION=us-east-1
# ANTICOPY_CACHE_DIR=/var/cache/anticopy        # local R2-blob cache; needs write perms


## ANTI-COPY (CEAC) — worker → remote GPU host
#
# The worker runs on the backend CPU box (where AWS / R2 credentials
# live) and drives sglang on a separate GPU host entirely over SSH.
# The GPU host never sees an AWS key.
#
# One GPU is enough — a 32 B Qwen3 bf16 model fits in ~64 GB of VRAM
# and the worker processes one candidate at a time. ``BASE_GPU_ID``
# is which card sglang should bind to when the worker auto-launches
# it; leave at 0 unless that card is taken by another workload.
#
# Inside one job the worker also:
#   * prefetches the next pending checkpoint into ``HF_CACHE`` while
#     the in-flight teacher-force is running (network is idle then)
#   * garbage-collects old HF snapshots after each job. The pool size
#     is controlled by ``anticopy.gc_keep_recent`` in SystemConfig
#     (default 3 = current + next + 1 prior), NOT an env var.
#
# ANTICOPY_REMOTE_SSH_HOST=user@gpu-host        # required for remote-SSH mode
# ANTICOPY_REMOTE_SSH_KEY=/root/.ssh/id_rsa     # private key (RO-mounted into worker)
# ANTICOPY_REMOTE_SSH_PORT=                     # only set when sshd is NOT on 22 (e.g. B300)
# ANTICOPY_REMOTE_PYTHON=/opt/affine-venv/bin/python  # path to python on the GPU host (must have sglang/torch installed)
# ANTICOPY_REMOTE_SGLANG_PORT=30000             # port sglang listens on, ON the GPU host
# ANTICOPY_SGLANG_URL=http://localhost:33000    # worker-side URL — points at an SSH local-forward to the remote sglang
# ANTICOPY_HF_CACHE=/workspace/hf               # HF snapshot cache dir on the GPU host
# ANTICOPY_BASE_GPU_ID=0                        # single GPU the worker pins sglang to (any 1 card with ≥64 GB VRAM)
# ANTICOPY_SGLANG_EXTRA_ARGS=                   # extra flags passed to sglang.launch_server (mem-fraction, attention-backend etc.)
